---
import Main from '../../layouts/Main.astro'
import { API_BASE } from '../../lib/config'

const { slug } = Astro.params
let products: any[] = []
let category: any = null
let pagination = { page: 1, limit: 20, total: 0, totalPages: 1 }

if (slug) {
  try {
    // 获取分类信息
    const catRes = await fetch(`${API_BASE}/categories/${slug}`)
    if (catRes.ok) category = await catRes.json()
    
    // 获取产品
    const prodRes = await fetch(`${API_BASE}/products?category=${category?.id || ''}&page=1&limit=20`)
    if (prodRes.ok) {
      const data = await prodRes.json()
      products = data.items || []
      pagination = data.pagination || pagination
    }
  } catch (e) {
    // fallback
  }
}

const categoryName = category?.name || 'Products'
const categoryDesc = category?.description || `Browse our collection of ${categoryName.toLowerCase()}`
---
<Main title={categoryName} description={categoryDesc}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-gray-500 mb-8">
      <a href="/" class="hover:text-brand-600">Home</a>
      <span>/</span>
      <span class="text-gray-900 font-medium">{categoryName}</span>
    </nav>

    <!-- Header -->
    <div class="mb-8">
      <h1 class="font-display text-3xl md:text-4xl font-bold text-gray-900">{categoryName}</h1>
      {category?.description && <p class="mt-2 text-gray-600">{category.description}</p>}
    </div>

    <!-- Products Grid -->
    {products.length > 0 ? (
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
        {products.map(product => {
          const images = typeof product.images === 'string' ? JSON.parse(product.images) : (product.images || [])
          return (
            <a href={`/products/${product.slug}`} class="group">
              <div class="aspect-square bg-gray-100 rounded-2xl overflow-hidden mb-3">
                <img src={images[0] || '/placeholder.svg'} alt={product.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              </div>
              <h3 class="text-sm font-medium text-gray-900 group-hover:text-brand-600 transition-colors">{product.title}</h3>
              <p class="mt-1 text-sm font-medium text-gray-900">${product.price.toFixed(2)}</p>
            </a>
          )
        })}
      </div>
    ) : (
      <div class="text-center py-20">
        <p class="text-gray-500">No products found in this category yet. Check back soon!</p>
      </div>
    )}

    <!-- Pagination -->
    {pagination.totalPages > 1 && (
      <div class="flex justify-center mt-12 gap-2">
        {Array.from({length: pagination.totalPages}, (_, i) => i + 1).map(p => (
          <a href={`/category/${slug}?page=${p}`} class={`px-4 py-2 rounded-lg text-sm ${p === pagination.page ? 'bg-gray-900 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}`}>
            {p}
          </a>
        ))}
      </div>
    )}
  </div>
</Main>
