---
import Main from '../../layouts/Main.astro'
import { API_BASE } from '../../lib/config'

const { slug } = Astro.params
let product: any = null

if (slug) {
  try {
    const res = await fetch(`${API_BASE}/products/${slug}`)
    if (res.ok) product = await res.json()
  } catch (e) {}
}

if (!product) {
  return Astro.redirect('/404')
}

const images = typeof product.images === 'string' ? JSON.parse(product.images) : (product.images || [])
const tags = typeof product.tags === 'string' ? JSON.parse(product.tags || '[]') : (product.tags || [])
const variants = typeof product.variants === 'string' ? JSON.parse(product.variants || '[]') : (product.variants || [])
const combinations = typeof product.variant_combinations === 'string' ? JSON.parse(product.variant_combinations || '[]') : (product.variant_combinations || [])
const seoTitle = product.seo_title || `${product.title} | XXDOG`
const seoDesc = product.seo_description || `Shop ${product.title} at XXDOG. ✓ Premium Quality ✓ Fast Shipping ✓ 30-Day Returns`
---
<Main title={product.title} description={seoDesc} image={images[0]}>
  <script>
    // Structured data for Product
    const productData = {
      "@context": "https://schema.org/",
      "@type": "Product",
      "name": {product.title},
      "image": {images.length > 0 ? images[0] : ''},
      "description": {product.description?.substring(0, 200) || seoDesc},
      "sku": {product.sku},
      "offers": {
        "@type": "Offer",
        "url": window.location.href,
        "priceCurrency": "USD",
        "price": {product.price},
        "availability": "https://schema.org/InStock",
        "shippingDetails": {
          "@type": "OfferShippingDetail",
          "shippingRate": {"@type": "MonetaryAmount", "value": 5.99, "currency": "USD"}
        }
      }
    };
    document.querySelector('#product-schema')?.remove();
    const script = document.createElement('script');
    script.id = 'product-schema';
    script.type = 'application/ld+json';
    script.textContent = JSON.stringify(productData);
    document.head.appendChild(script);
  </script>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-gray-500 mb-8">
      <a href="/" class="hover:text-brand-600">Home</a>
      <span>/</span>
      <a href="/category/{product.category_id}" class="hover:text-brand-600">Products</a>
      <span>/</span>
      <span class="text-gray-900 font-medium">{product.title}</span>
    </nav>

    <div class="grid md:grid-cols-2 gap-8 lg:gap-12">
      <!-- Images -->
      <div class="space-y-4">
        <div class="aspect-square bg-gray-100 rounded-2xl overflow-hidden">
          <img src={images[0] || '/placeholder.svg'} alt={product.title} class="w-full h-full object-cover" id="main-image" />
        </div>
        {images.length > 1 && (
          <div class="grid grid-cols-4 gap-2">
            {images.map((img: string, i: number) => (
              <button class="aspect-square bg-gray-100 rounded-lg overflow-hidden border-2 border-transparent hover:border-brand-400 transition-colors {i === 0 ? 'border-brand-600' : ''}" onclick="document.getElementById('main-image').src=this.querySelector('img').src; document.querySelectorAll('[data-thumb]').forEach(t=>t.classList.remove('border-brand-600')); this.classList.add('border-brand-600')" data-thumb>
                <img src={img} alt={`{product.title} view ${i+1}`} class="w-full h-full object-cover" loading="lazy" />
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- Details -->
      <div>
        <span class="text-xs font-semibold uppercase tracking-wider text-brand-600">SKU: {product.sku}</span>
        <h1 class="mt-2 font-display text-3xl md:text-4xl font-bold text-gray-900">{product.title}</h1>
        
        <div class="mt-4 flex items-baseline gap-3">
          <span class="text-3xl font-bold text-gray-900">${product.price.toFixed(2)}</span>
          {product.compare_price && product.compare_price > product.price && (
            <span class="text-lg text-gray-400 line-through">${product.compare_price.toFixed(2)}</span>
          )}
        </div>

        {product.description && (
          <div class="mt-6 prose prose-gray max-w-none">
            {product.description.split('\n').map(p => <p class="text-gray-600 text-sm leading-relaxed">{p}</p>)}
          </div>
        )}

        {/* Variants */}
        {variants.length > 0 && variants.map((variant: any) => (
          <div class="mt-6">
            <h3 class="text-sm font-semibold text-gray-900 mb-2">{variant.name}</h3>
            <div class="flex flex-wrap gap-2">
              {variant.options.map((opt: string) => (
                <button class="px-4 py-2 border border-gray-300 rounded-lg text-sm hover:border-gray-900 transition-colors data-[selected]:bg-gray-900 data-[selected]:text-white" onclick="document.querySelectorAll('[data-variant-{variant.name}]').forEach(b=>b.removeAttribute('data-selected')); this.dataset.selected=''">
                  {opt}
                </button>
              ))}
            </div>
          </div>
        ))}

        {/* Quantity */}
        <div class="mt-6">
          <h3 class="text-sm font-semibold text-gray-900 mb-2">Quantity</h3>
          <div class="flex items-center gap-3">
            <button class="w-10 h-10 rounded-full border border-gray-300 flex items-center justify-center hover:bg-gray-100" onclick="const q=document.getElementById('qty'); const v=parseInt(q.value); if(v>1) q.value=v-1">−</button>
            <input id="qty" type="number" value="1" min="1" max="{product.stock || 99}" class="w-16 text-center border border-gray-300 rounded-lg py-2" />
            <button class="w-10 h-10 rounded-full border border-gray-300 flex items-center justify-center hover:bg-gray-100" onclick="const q=document.getElementById('qty'); const v=parseInt(q.value); q.value=v+1">+</button>
          </div>
        </div>

        {/* Add to Cart */}
        <div class="mt-8 flex gap-3">
          <button class="flex-1 px-8 py-3 bg-gray-900 text-white font-medium rounded-full hover:bg-gray-800 transition-colors" onclick='addToCart({product.id}, "{product.title}", {product.price}, "{images[0] || ""}")'>
            Add to Cart
          </button>
          <button class="px-8 py-3 bg-brand-600 text-white font-medium rounded-full hover:bg-brand-700 transition-colors">
            Buy Now
          </button>
        </div>

        {/* Tags */}
        {tags.length > 0 && (
          <div class="mt-6 flex flex-wrap gap-2">
            {tags.map((tag: string) => (
              <span class="px-3 py-1 bg-gray-100 text-xs text-gray-600 rounded-full">{tag}</span>
            ))}
          </div>
        )}

        {/* Shipping info */}
        <div class="mt-8 p-4 bg-gray-50 rounded-xl space-y-2 text-sm text-gray-600">
          <p>✓ Free shipping on orders over $50</p>
          <p>✓ 30-day easy returns</p>
          <p>✓ Secure checkout with PayPal & Stripe</p>
        </div>
      </div>
    </div>
  </div>

  <script>
    function addToCart(id, title, price, image) {
      const qty = parseInt(document.getElementById('qty')?.value || '1');
      const cart = JSON.parse(localStorage.getItem('cart') || '{"items":[]}');
      
      const existing = cart.items.findIndex(i => i.product_id === id);
      if (existing >= 0) {
        cart.items[existing].qty += qty;
      } else {
        cart.items.push({ product_id: id, title, price, qty, image });
      }
      
      localStorage.setItem('cart', JSON.stringify(cart));
      
      const count = cart.items.reduce((s, i) => s + i.qty, 0);
      const badge = document.getElementById('cart-count');
      if (badge) {
        badge.textContent = count;
        badge.classList.remove('hidden');
      }
      
      alert('Added to cart!');
    }
  </script>
</Main>
