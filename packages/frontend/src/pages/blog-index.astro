---
import Main from '../layouts/Main.astro'
import { API_BASE } from '../lib/config'

let posts: any[] = []
let pagination = { page: 1, limit: 10, total: 0, totalPages: 1 }

try {
  const res = await fetch(`${API_BASE}/blog?page=1&limit=10`)
  if (res.ok) {
    const data = await res.json()
    posts = data.items || []
    pagination = data.pagination || pagination
  }
} catch (e) {}
---
<Main title="Blog" description="Fashion tips, style guides and more from XXDOG">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="font-display text-3xl md:text-4xl font-bold text-gray-900 mb-2">Blog</h1>
    <p class="text-gray-600 mb-8">Fashion tips, style guides, and the latest trends</p>

    {posts.length > 0 ? (
      <div class="space-y-8">
        {posts.map(post => (
          <a href={`/blog/${post.slug}`} class="group block">
            <article class="grid md:grid-cols-3 gap-6 items-start">
              {post.cover_image && (
                <div class="aspect-[4/3] bg-gray-100 rounded-xl overflow-hidden">
                  <img src={post.cover_image} alt={post.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                </div>
              )}
              <div class={post.cover_image ? 'md:col-span-2' : 'md:col-span-3'}>
                <h2 class="font-display text-xl font-bold text-gray-900 group-hover:text-brand-600 transition-colors">{post.title}</h2>
                {post.excerpt && <p class="mt-2 text-gray-600 text-sm">{post.excerpt}</p>}
                {post.published_at && (
                  <p class="mt-3 text-xs text-gray-400">{new Date(post.published_at).toLocaleDateString('en-US', {year: 'numeric', month: 'long', day: 'numeric'})}</p>
                )}
              </div>
            </article>
          </a>
        ))}
      </div>
    ) : (
      <div class="text-center py-20">
        <p class="text-gray-500">No blog posts yet. Coming soon!</p>
      </div>
    )}
  </div>
</Main>
