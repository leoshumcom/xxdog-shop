---
import Main from '../layouts/Main.astro'
---
<Main title="Cart" description="Your shopping cart">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="font-display text-3xl font-bold text-gray-900 mb-8">Shopping Cart</h1>
    
    <div id="cart-content">
      <!-- 客户端渲染购物车 -->
      <div class="text-center py-12">
        <p class="text-gray-500">Loading cart...</p>
      </div>
    </div>
  </div>

  <script>
    function renderCart() {
      const cart = JSON.parse(localStorage.getItem('cart') || '{"items":[]}');
      const container = document.getElementById('cart-content');
      
      if (cart.items.length === 0) {
        container.innerHTML = `
          <div class="text-center py-20">
            <p class="text-gray-500 text-lg mb-4">Your cart is empty</p>
            <a href="/category/shoes" class="inline-flex items-center px-6 py-3 bg-gray-900 text-white rounded-full hover:bg-gray-800">Start Shopping</a>
          </div>
        `;
        return;
      }
      
      const subtotal = cart.items.reduce((s, i) => s + i.price * i.qty, 0);
      const shipping = subtotal >= 50 ? 0 : 5.99;
      const total = subtotal + shipping;
      
      let html = '';
      cart.items.forEach((item, idx) => {
        html += `
          <div class="flex gap-4 py-4 border-b border-gray-200" data-index="${idx}">
            <div class="w-20 h-20 bg-gray-100 rounded-lg overflow-hidden flex-shrink-0">
              <img src="${item.image || '/placeholder.svg'}" alt="${item.title}" class="w-full h-full object-cover" />
            </div>
            <div class="flex-1">
              <h3 class="font-medium text-gray-900">${item.title}</h3>
              <p class="text-sm text-gray-600 mt-1">$${item.price.toFixed(2)}</p>
              <div class="flex items-center gap-2 mt-2">
                <button class="w-7 h-7 border border-gray-300 rounded-full text-sm" onclick="updateQty(${idx}, -1)">−</button>
                <span class="w-8 text-center text-sm">${item.qty}</span>
                <button class="w-7 h-7 border border-gray-300 rounded-full text-sm" onclick="updateQty(${idx}, 1)">+</button>
                <button class="ml-4 text-sm text-red-500 hover:text-red-700" onclick="removeItem(${idx})">Remove</button>
              </div>
            </div>
            <div class="text-right">
              <p class="font-medium text-gray-900">$${(item.price * item.qty).toFixed(2)}</p>
            </div>
          </div>
        `;
      });
      
      html += `
        <div class="mt-6 space-y-2">
          <div class="flex justify-between text-sm text-gray-600">
            <span>Subtotal</span>
            <span>$${subtotal.toFixed(2)}</span>
          </div>
          <div class="flex justify-between text-sm text-gray-600">
            <span>Shipping</span>
            <span>${shipping === 0 ? '<span class="text-green-600">Free</span>' : '$5.99'}</span>
          </div>
          ${subtotal < 50 ? '<p class="text-xs text-brand-600">Add $' + (50 - subtotal).toFixed(2) + ' more for free shipping!</p>' : ''}
          <div class="flex justify-between text-lg font-bold text-gray-900 pt-3 border-t border-gray-200">
            <span>Total</span>
            <span>$${total.toFixed(2)} USD</span>
          </div>
        </div>
        
        <div class="mt-8 space-y-3">
          <button class="w-full py-3 bg-brand-600 text-white font-medium rounded-full hover:bg-brand-700 transition-colors" onclick="checkout()">
            Proceed to Checkout
          </button>
          <a href="/category/shoes" class="block text-center text-sm text-gray-600 hover:text-brand-600">Continue Shopping</a>
        </div>
      `;
      
      container.innerHTML = html;
      updateBadge();
    }
    
    function updateQty(idx, delta) {
      const cart = JSON.parse(localStorage.getItem('cart') || '{"items":[]}');
      cart.items[idx].qty = Math.max(1, cart.items[idx].qty + delta);
      localStorage.setItem('cart', JSON.stringify(cart));
      renderCart();
    }
    
    function removeItem(idx) {
      const cart = JSON.parse(localStorage.getItem('cart') || '{"items":[]}');
      cart.items.splice(idx, 1);
      localStorage.setItem('cart', JSON.stringify(cart));
      renderCart();
    }
    
    function updateBadge() {
      const cart = JSON.parse(localStorage.getItem('cart') || '{"items":[]}');
      const count = cart.items.reduce((s, i) => s + i.qty, 0);
      const badge = document.getElementById('cart-count');
      if (badge) {
        if (count > 0) {
          badge.textContent = count;
          badge.classList.remove('hidden');
        } else {
          badge.classList.add('hidden');
        }
      }
    }
    
    function checkout() {
      const cart = JSON.parse(localStorage.getItem('cart') || '{"items":[]}');
      // Store cart for checkout page
      sessionStorage.setItem('checkout_cart', JSON.stringify(cart));
      window.location.href = '/checkout';
    }
    
    renderCart();
  </script>
</Main>
