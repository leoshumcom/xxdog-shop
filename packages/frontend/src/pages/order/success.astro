---
import Main from '../layouts/Main.astro'
---
<Main title="Order Confirmed" description="Thank you for your order">
  <div class="max-w-lg mx-auto px-4 py-20 text-center">
    <div class="w-16 h-16 mx-auto mb-4 bg-green-100 rounded-full flex items-center justify-center">
      <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
    </div>
    <h1 class="font-display text-3xl font-bold text-gray-900 mb-2">Order Confirmed!</h1>
    <p class="text-gray-600 mb-8">Thank you for your purchase. You'll receive an email confirmation shortly.</p>
    <a href="/" class="inline-flex items-center px-8 py-3 bg-gray-900 text-white rounded-full hover:bg-gray-800">Continue Shopping</a>
  </div>
</Main>
